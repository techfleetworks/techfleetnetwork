/*
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 0
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(self), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), display-capture=(), document-domain=(), encrypted-media=(), fullscreen=(self), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://accounts.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.supabase.co; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://accounts.google.com https://ai.gateway.lovable.dev https://api.firecrawl.dev; frame-src https://accounts.google.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests; object-src 'none'; worker-src 'self' blob:;
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless
  X-Permitted-Cross-Domain-Policies: none
  X-DNS-Prefetch-Control: off
  X-Download-Options: noopen
  NEL: {"report_to":"default","max_age":2592000,"include_subdomains":true}
  Report-To: {"group":"default","max_age":2592000,"endpoints":[{"url":"https://techfleetnetwork.lovable.app/api/csp-report"}],"include_subdomains":true}

