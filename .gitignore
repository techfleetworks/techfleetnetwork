# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment variables — never commit secrets.
# Lovable auto-generates a local .env with publishable keys only, but
# ignoring the whole family prevents accidental commits of private keys,
# service-role tokens, or per-developer overrides.
.env
.env.*
!.env.example

# Test / audit output
a11y-report/
playwright-report/
test-results/
coverage/
sbom.json

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
